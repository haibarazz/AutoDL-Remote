#!/usr/bin/env bash
set -u

PROGRAM="autodl-remote"
PROGRAM_VERSION="0.7.0"
APP_DIR="$HOME/.autodl-remote"
ACCOUNTS_DIR="$APP_DIR/accounts"
DEFAULT_ACCOUNT_FILE="$APP_DIR/default-account"
CONFIG_FILE=".autodl-remote.conf"
HISTORY_DIR=".autodl-remote"
KEYCHAIN_SERVICE="autodl-remote"

die() {
  printf '%s: %s\n' "$PROGRAM" "$*" >&2
  exit 2
}

info() {
  printf '%s\n' "$*"
}

usage() {
  cat <<'EOF'
usage: autodl-remote <command> [options]

general:
  --version
  version

account:
  account add <name> [--target root@host | --host host --user root] [--port 22] [--key path] [--auth prompt|keychain|ssh-key] [--default-remote path]
  account list
  account show <name>
  account use <name>
  account test [name]
  account password-save <name>
  account password-delete <name>

project:
  bind [--account name] --remote /remote/project/root
  doctor
  model-dir [--mkdir]
  fleet create <name>
  fleet add <fleet> <device> [--account name] [--remote path] [--tags tags]
  fleet list
  fleet status [fleet]
  dashboard [--fleet name] [--output path] [--open] [--watch seconds] [--lines 120]

remote:
  exec [--account name] [--remote path] [--detach] [--cwd path] [--name name] [--model name] [--tag k=v] [--stage stage] [--purpose text] [--script local_script] [--stdin] [--allow-dangerous] -- <command>
  put-run <local-path>... -- <command>
  put [--account name] [--remote path] <local-path> [remote-path]
  get [--account name] [--remote path] <remote-path> [local-path]
  sync-up [--account name] [--remote path] <local-path> [remote-path]
  sync-down [--account name] [--remote path] <remote-path> [local-path]
  tree [--account name] [--remote path] [remote-path] [--depth 3] [--limit 500]
  ls [--account name] [--remote path] [remote-path]
  cat [--account name] [--remote path] [--lines 200] -- <remote-path>
  tail [--account name] [--remote path] [--lines 120] [--follow] -- <remote-path>
  job list
  job status <name>
  job tail [--lines 120] [--follow] <name>
  run submit [metadata/options] -- <command>
  run list
  run status <name>
  run tail [--lines 120] [--follow] <name>
  run note <name> [--model name] [--tag k=v] [--stage stage] [--purpose text] [--output path]
  shutdown [--wait seconds]
  shell
  history [--lines 20]

EOF
}

cmd_version() {
  printf '%s %s\n' "$PROGRAM" "$PROGRAM_VERSION"
}

shell_quote() {
  printf '%q' "$1"
}

strip_quotes() {
  local value="$1"
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  value="${value%%#*}"
  value="${value%"${value##*[![:space:]]}"}"
  case "$value" in
    \"*\") value="${value#\"}"; value="${value%\"}" ;;
    \'*\') value="${value#\'}"; value="${value%\'}" ;;
  esac
  printf '%s' "$value"
}

json_escape() {
  sed 's/\\/\\\\/g; s/"/\\"/g' <<EOF
$1
EOF
}

html_escape() {
  sed 's/&/\&amp;/g; s/</\&lt;/g; s/>/\&gt;/g; s/"/\&quot;/g' <<EOF
$1
EOF
}

valid_name() {
  case "$1" in
    ""|*/*|*..*|*[\ \	]*) return 1 ;;
  esac
  return 0
}

append_csv() {
  local current="$1" value="$2"
  if [ -n "$current" ]; then
    printf '%s,%s\n' "$current" "$value"
  else
    printf '%s\n' "$value"
  fi
}

ensure_app_dirs() {
  mkdir -p "$ACCOUNTS_DIR" "$APP_DIR"
}

account_path() {
  local name="$1"
  valid_name "$name" || die "Invalid account name: $name"
  ensure_app_dirs
  printf '%s/%s.conf\n' "$ACCOUNTS_DIR" "$name"
}

config_get_from() {
  local file="$1" key="$2"
  awk -F= -v key="$key" '
    $0 ~ "^[[:space:]]*" key "[[:space:]]*=" {
      sub(/^[^=]*=/, "", $0)
      print $0
      exit
    }
  ' "$file" | while IFS= read -r line; do strip_quotes "$line"; done
}

find_project_config() {
  if [ -n "${AUTODL_REMOTE_CONFIG:-}" ]; then
    [ -f "$AUTODL_REMOTE_CONFIG" ] || die "AUTODL_REMOTE_CONFIG points to a missing file: $AUTODL_REMOTE_CONFIG"
    printf '%s\n' "$AUTODL_REMOTE_CONFIG"
    return 0
  fi

  local dir
  dir="$(pwd)"
  while :; do
    if [ -f "$dir/$CONFIG_FILE" ]; then
      printf '%s\n' "$dir/$CONFIG_FILE"
      return 0
    fi
    [ "$dir" = "/" ] && break
    dir="$(dirname "$dir")"
  done
  die "No $CONFIG_FILE found. Run 'autodl-remote bind --account <name> --remote <path>'."
}

validate_remote_root() {
  local root="${1%/}"
  [ "${root#/}" != "$root" ] || die "remote path must be absolute: $root"
  [ "$root" != "/" ] || die "remote path is too broad: /"
  case "$root" in
    *"/../"*|*/..) die "remote path cannot contain '..': $root" ;;
  esac
}

write_history() {
  local action="$1" detail="$2" file escaped
  mkdir -p "$PROJECT_ROOT/$HISTORY_DIR"
  file="$PROJECT_ROOT/$HISTORY_DIR/history.jsonl"
  escaped="$(json_escape "$detail")"
  printf '{"ts":"%s","action":"%s","detail":"%s"}\n' "$(date +%Y-%m-%dT%H:%M:%S%z)" "$action" "$escaped" >> "$file"
}

sanitize_name() {
  local name="$1"
  name="$(printf '%s' "$name" | sed 's/[^A-Za-z0-9_.-]/-/g')"
  [ -n "$name" ] || name="job-$(date +%Y%m%d-%H%M%S)"
  printf '%s\n' "$name"
}

config_quote() {
  sed 's/\\/\\\\/g; s/"/\\"/g' <<EOF
$1
EOF
}

default_model_dir() {
  case "$REMOTE_ROOT" in
    /root/autodl-tmp|/root/autodl-tmp/*) printf '%s\n' "/root/autodl-tmp/models" ;;
    *) printf '%s\n' "$REMOTE_ROOT/models" ;;
  esac
}

ensure_project_conventions() {
  local dir file
  dir="$PROJECT_ROOT/$HISTORY_DIR"
  file="$dir/CONVENTIONS.md"
  mkdir -p "$dir"
  [ -f "$file" ] && return 0
  cat > "$file" <<EOF
# AutoDL Remote Conventions

This file is created locally by \`autodl-remote\` to record project-specific remote workflow conventions.

## Runtime

- Activate command: \`<fill me, e.g. conda activate env or source .venv/bin/activate>\`
- Python command: \`python\`
- Install packages: ask before installing

## Remote Paths

- Remote root: \`$REMOTE_ROOT\`
- Model dir: \`$PROJECT_MODEL_DIR\`
- Data dir: \`<fill me>\`
- Output dir: \`<fill me>\`

## Sync Rules

- Edit code locally first, then upload selected files.
- Do not download models, datasets, checkpoints, or large outputs unless explicitly asked.
- Prefer remote \`cat\`, \`tail\`, \`ls\`, and \`tree\` before downloading files.

## Notes

- Add project-specific notes here.
EOF
}

jobs_dir() {
  printf '%s/%s/jobs\n' "$PROJECT_ROOT" "$HISTORY_DIR"
}

job_path() {
  local name="$1"
  valid_name "$name" || die "Invalid job name: $name"
  printf '%s/%s.conf\n' "$(jobs_dir)" "$name"
}

write_job() {
  local name="$1" pid="$2" log="$3" status_path="$4" cwd="$5" command="$6" model="${7:-}" tags="${8:-}" purpose="${9:-}" stage="${10:-}" outputs="${11:-}" file
  mkdir -p "$(jobs_dir)"
  file="$(job_path "$name")"
  cat > "$file" <<EOF
NAME="$(config_quote "$name")"
PID="$(config_quote "$pid")"
ACCOUNT="$(config_quote "$ACCOUNT_NAME")"
REMOTE_ROOT="$(config_quote "$REMOTE_ROOT")"
LOG_PATH="$(config_quote "$log")"
STATUS_PATH="$(config_quote "$status_path")"
CWD="$(config_quote "$cwd")"
STARTED_AT="$(date +%Y-%m-%dT%H:%M:%S%z)"
COMMAND="$(config_quote "$command")"
MODEL="$(config_quote "$model")"
TAGS="$(config_quote "$tags")"
PURPOSE="$(config_quote "$purpose")"
STAGE="$(config_quote "$stage")"
OUTPUTS="$(config_quote "$outputs")"
EOF
}

job_get() {
  local file="$1" key="$2"
  config_get_from "$file" "$key"
}

config_set_in_file() {
  local file="$1" key="$2" value="$3" quoted tmp
  quoted="$(config_quote "$value")"
  tmp="$file.tmp"
  awk -F= -v key="$key" -v quoted="$quoted" '
    BEGIN { done=0 }
    $1 == key {
      if (!done) {
        print key "=\"" quoted "\""
        done=1
      }
      next
    }
    { print }
    END {
      if (!done) print key "=\"" quoted "\""
    }
  ' "$file" > "$tmp"
  mv "$tmp" "$file"
}

apply_context_override() {
  local account="${1:-}" remote="${2:-}"
  if [ -n "$account" ]; then
    load_account "$account"
    PROJECT_ACCOUNT="$ACCOUNT_NAME"
    if [ -z "$remote" ] && [ -n "$ACCOUNT_DEFAULT_REMOTE" ]; then
      remote="$ACCOUNT_DEFAULT_REMOTE"
    fi
  fi
  if [ -n "$remote" ]; then
    REMOTE_ROOT="${remote%/}"
    validate_remote_root "$REMOTE_ROOT"
    PROJECT_MODEL_DIR="$(default_model_dir)"
  fi
}

fleet_root() {
  printf '%s/%s/fleets\n' "$PROJECT_ROOT" "$HISTORY_DIR"
}

fleet_dir() {
  local name="$1"
  valid_name "$name" || die "Invalid fleet name: $name"
  printf '%s/%s\n' "$(fleet_root)" "$name"
}

fleet_device_path() {
  local fleet="$1" device="$2"
  valid_name "$device" || die "Invalid device name: $device"
  printf '%s/%s.conf\n' "$(fleet_dir "$fleet")" "$device"
}

device_get() {
  local file="$1" key="$2"
  config_get_from "$file" "$key"
}

apply_job_context() {
  local file="$1" account remote
  account="$(job_get "$file" ACCOUNT)"
  remote="$(job_get "$file" REMOTE_ROOT)"
  [ -n "$account" ] || account="${PROJECT_BOUND_ACCOUNT:-$PROJECT_ACCOUNT}"
  [ -n "$remote" ] || remote="${PROJECT_BOUND_REMOTE_ROOT:-$REMOTE_ROOT}"
  apply_context_override "$account" "$remote"
}

job_remote_status_summary() {
  local file="$1" pid status_path output rc status alive
  apply_job_context "$file"
  pid="$(job_get "$file" PID)"
  status_path="$(job_get "$file" STATUS_PATH)"
  output="$(ssh_capture "if [ -f $(shell_quote "$status_path") ]; then cat $(shell_quote "$status_path"); elif kill -0 $(shell_quote "$pid") 2>/dev/null; then printf 'status=running\npid=%s\n' $(shell_quote "$pid"); else printf 'status=unknown\npid=%s\n' $(shell_quote "$pid"); fi; if kill -0 $(shell_quote "$pid") 2>/dev/null; then echo alive=yes; else echo alive=no; fi" 2>/dev/null)"
  rc=$?
  if [ "$rc" -ne 0 ]; then
    printf 'unreachable\n'
    return 0
  fi
  status="$(printf '%s\n' "$output" | awk -F= '$1=="status"{print $2; exit}')"
  alive="$(printf '%s\n' "$output" | awk -F= '$1=="alive"{print $2; exit}')"
  [ -n "$status" ] || status="unknown"
  if [ "$alive" = "yes" ] && [ "$status" = "unknown" ]; then
    status="running"
  fi
  printf '%s\n' "$status"
}

remote_probe() {
  local output rc
  output="$(ssh_capture "root=$(shell_quote "$REMOTE_ROOT"); printf 'online=yes\n'; printf 'host='; hostname 2>/dev/null || echo unknown; printf 'remote_root=%s\n' \"\$root\"; printf 'disk='; df -h \"\$root\" 2>/dev/null | awk 'NR==2{print \$3 \"/\" \$2 \" \" \$5}' || echo unknown; if command -v nvidia-smi >/dev/null 2>&1; then printf 'gpu='; nvidia-smi --query-gpu=name,memory.used,memory.total,utilization.gpu --format=csv,noheader,nounits 2>/dev/null | head -n 1 | awk -F, '{gsub(/^ +| +$/, \"\", \$1); gsub(/^ +| +$/, \"\", \$2); gsub(/^ +| +$/, \"\", \$3); gsub(/^ +| +$/, \"\", \$4); print \$1 \" \" \$2 \"/\" \$3 \" MiB \" \$4 \"%\"}'; else echo 'gpu=unavailable'; fi; printf 'processes='; pgrep -af 'python|torchrun|accelerate' 2>/dev/null | head -n 3 | tr '\n' '|' | sed 's/|$//'; printf '\n'" 2>&1)"
  rc=$?
  if [ "$rc" -eq 0 ]; then
    printf '%s\n' "$output"
  else
    printf 'online=no\n'
    printf 'error=%s\n' "$(printf '%s' "$output" | head -n 1)"
  fi
}

kv_get() {
  local data="$1" key="$2"
  printf '%s\n' "$data" | awk -F= -v key="$key" '$1==key{print substr($0, length(key)+2); exit}'
}

load_account() {
  local name="$1" path
  valid_name "$name" || die "Invalid account name: $name"
  path="$(account_path "$name")"
  [ -f "$path" ] || die "Account not found: $name"

  ACCOUNT_NAME="$name"
  ACCOUNT_FILE="$path"
  ACCOUNT_HOST="$(config_get_from "$path" HOST)"
  ACCOUNT_USER="$(config_get_from "$path" USER)"
  ACCOUNT_TARGET="$(config_get_from "$path" TARGET)"
  ACCOUNT_PORT="$(config_get_from "$path" PORT)"
  ACCOUNT_KEY="$(config_get_from "$path" KEY)"
  ACCOUNT_AUTH="$(config_get_from "$path" AUTH)"
  ACCOUNT_DEFAULT_REMOTE="$(config_get_from "$path" DEFAULT_REMOTE)"

  if [ -z "$ACCOUNT_TARGET" ]; then
    [ -n "$ACCOUNT_HOST" ] || die "Account $name is missing HOST/TARGET."
    [ -n "$ACCOUNT_USER" ] || die "Account $name is missing USER/TARGET."
    ACCOUNT_TARGET="$ACCOUNT_USER@$ACCOUNT_HOST"
  fi
  ACCOUNT_PORT="${ACCOUNT_PORT:-22}"
  ACCOUNT_KEY="${ACCOUNT_KEY:-}"
  ACCOUNT_AUTH="${ACCOUNT_AUTH:-prompt}"
  ACCOUNT_DEFAULT_REMOTE="${ACCOUNT_DEFAULT_REMOTE:-}"

  case "$ACCOUNT_AUTH" in
    prompt|keychain|ssh-key) ;;
    *) die "Account $name has invalid AUTH: $ACCOUNT_AUTH" ;;
  esac
}

default_account() {
  if [ -f "$DEFAULT_ACCOUNT_FILE" ]; then
    sed -n '1p' "$DEFAULT_ACCOUNT_FILE"
    return 0
  fi
  return 1
}

load_project() {
  CONFIG_PATH="$(find_project_config)"
  PROJECT_ROOT="$(cd "$(dirname "$CONFIG_PATH")" && pwd)"
  PROJECT_ACCOUNT="$(config_get_from "$CONFIG_PATH" ACCOUNT)"
  REMOTE_ROOT="$(config_get_from "$CONFIG_PATH" REMOTE_ROOT)"
  PROJECT_MODEL_DIR="$(config_get_from "$CONFIG_PATH" MODEL_DIR)"

  [ -n "$PROJECT_ACCOUNT" ] || die "$CONFIG_FILE is missing ACCOUNT."
  load_account "$PROJECT_ACCOUNT"

  [ -n "$REMOTE_ROOT" ] || REMOTE_ROOT="$ACCOUNT_DEFAULT_REMOTE"
  [ -n "$REMOTE_ROOT" ] || die "$CONFIG_FILE is missing REMOTE_ROOT."
  REMOTE_ROOT="${REMOTE_ROOT%/}"
  validate_remote_root "$REMOTE_ROOT"
  [ -n "$PROJECT_MODEL_DIR" ] || PROJECT_MODEL_DIR="$(default_model_dir)"
  case "$PROJECT_MODEL_DIR" in
    /*) ;;
    *) PROJECT_MODEL_DIR="$REMOTE_ROOT/${PROJECT_MODEL_DIR#./}" ;;
  esac
  PROJECT_MODEL_DIR="${PROJECT_MODEL_DIR%/}"
  validate_remote_root "$PROJECT_MODEL_DIR"
  PROJECT_BOUND_ACCOUNT="$PROJECT_ACCOUNT"
  PROJECT_BOUND_REMOTE_ROOT="$REMOTE_ROOT"
  ensure_project_conventions
}

ssh_common_args() {
  local control_path
  control_path="$(ssh_control_path)"
  SSH_ARGS=(-p "$ACCOUNT_PORT" -o ServerAliveInterval=30 -o ServerAliveCountMax=3 -o ControlMaster=auto -o ControlPersist=600 -o "ControlPath=$control_path")
  [ -n "$ACCOUNT_KEY" ] && SSH_ARGS+=(-i "$ACCOUNT_KEY")
  if [ "$ACCOUNT_AUTH" != "keychain" ] && [ "$ACCOUNT_AUTH" != "prompt" ]; then
    SSH_ARGS+=(-o BatchMode=yes)
  fi
}

scp_common_args() {
  local control_path
  control_path="$(ssh_control_path)"
  SCP_ARGS=(-P "$ACCOUNT_PORT" -o ServerAliveInterval=30 -o ServerAliveCountMax=3 -o ControlMaster=auto -o ControlPersist=600 -o "ControlPath=$control_path")
  [ -n "$ACCOUNT_KEY" ] && SCP_ARGS+=(-i "$ACCOUNT_KEY")
  if [ "$ACCOUNT_AUTH" != "keychain" ] && [ "$ACCOUNT_AUTH" != "prompt" ]; then
    SCP_ARGS+=(-o BatchMode=yes)
  fi
}

rsync_ssh_command() {
  local cmd control_path
  control_path="$(ssh_control_path)"
  cmd="ssh -p $(shell_quote "$ACCOUNT_PORT") -o ServerAliveInterval=30 -o ServerAliveCountMax=3 -o ControlMaster=auto -o ControlPersist=600 -o ControlPath=$(shell_quote "$control_path")"
  [ -n "$ACCOUNT_KEY" ] && cmd="$cmd -i $(shell_quote "$ACCOUNT_KEY")"
  if [ "$ACCOUNT_AUTH" != "keychain" ] && [ "$ACCOUNT_AUTH" != "prompt" ]; then
    cmd="$cmd -o BatchMode=yes"
  fi
  printf '%s\n' "$cmd"
}

ssh_control_dir() {
  local base
  base="${AUTODL_REMOTE_CONTROL_DIR:-/tmp/autodl-remote-${UID:-user}}"
  mkdir -p "$base"
  chmod 700 "$base" 2>/dev/null || true
  printf '%s\n' "$base"
}

ssh_control_path() {
  printf '%s/ssh-%%C\n' "$(ssh_control_dir)"
}

keychain_password() {
  command -v security >/dev/null 2>&1 || die "macOS security command is not available."
  security find-generic-password -a "$ACCOUNT_NAME" -s "$KEYCHAIN_SERVICE" -w 2>/dev/null
}

expect_with_password() {
  command -v expect >/dev/null 2>&1 || die "Account uses keychain auth, but expect is not available."
  local password="$1"
  shift
  AUTODL_REMOTE_PASSWORD="$password" expect -f /dev/stdin "$@" <<'EXPECT'
    set timeout -1
    set password $env(AUTODL_REMOTE_PASSWORD)
    spawn {*}$argv
    expect {
      -re "(?i)are you sure you want to continue connecting" {
        send "yes\r"
        exp_continue
      }
      -re "(?i)password:" {
        send "$password\r"
        exp_continue
      }
      eof
    }
    catch wait result
    exit [lindex $result 3]
EXPECT
}

run_transport() {
  if [ "$ACCOUNT_AUTH" = "keychain" ]; then
    local password
    password="$(keychain_password)" || die "No Keychain password saved for account: $ACCOUNT_NAME"
    expect_with_password "$password" "$@"
  else
    "$@"
  fi
}

ssh_run() {
  local command="$1"
  ssh_common_args
  run_transport ssh "${SSH_ARGS[@]}" "$ACCOUNT_TARGET" "$command"
}

ssh_capture() {
  local command="$1"
  ssh_common_args
  run_transport ssh "${SSH_ARGS[@]}" "$ACCOUNT_TARGET" "$command"
}

remote_join() {
  local path="${1:-.}"
  if [ -z "$path" ] || [ "$path" = "." ]; then
    printf '%s\n' "$REMOTE_ROOT"
    return 0
  fi
  case "$path" in
    /*)
      validate_remote_root "$path"
      printf '%s\n' "${path%/}"
      ;;
    ../*|*/../*|..)
      die "path cannot escape remote root: $path"
      ;;
    *)
      printf '%s/%s\n' "$REMOTE_ROOT" "${path#./}"
      ;;
  esac
}

remote_rel_for_local() {
  local path="$1"
  case "$path" in
    /*)
      if [ "${path#"$PROJECT_ROOT"/}" != "$path" ]; then
        printf '%s\n' "${path#"$PROJECT_ROOT"/}"
      else
        basename "$path"
      fi
      ;;
    *)
      printf '%s\n' "${path#./}"
      ;;
  esac
}

local_join() {
  local path="$1"
  case "$path" in
    /*) printf '%s\n' "$path" ;;
    *) printf '%s/%s\n' "$PROJECT_ROOT" "${path#./}" ;;
  esac
}

remote_has_rsync() {
  ssh_capture "command -v rsync >/dev/null 2>&1" >/dev/null 2>&1
}

ensure_remote_dir() {
  local dir="$1"
  ssh_capture "mkdir -p $(shell_quote "$dir")" </dev/null >/dev/null
}

upload_local_file() {
  local local_path="$1" remote_path="$2"
  [ -f "$local_path" ] || die "Local script does not exist or is not a file: $local_path"
  ensure_remote_dir "$(dirname "$remote_path")"
  scp_common_args
  run_transport scp "${SCP_ARGS[@]}" "$local_path" "$ACCOUNT_TARGET:$remote_path"
}

upload_stdin_to_remote() {
  local remote_path="$1"
  ensure_remote_dir "$(dirname "$remote_path")"
  ssh_common_args
  run_transport ssh "${SSH_ARGS[@]}" "$ACCOUNT_TARGET" "cat > $(shell_quote "$remote_path")"
}

upload_file_via_ssh() {
  local local_path="$1" remote_path="$2"
  [ -f "$local_path" ] || die "Local script does not exist or is not a file: $local_path"
  upload_stdin_to_remote "$remote_path" < "$local_path"
}

strip_token_quotes() {
  local value="$1"
  value="${value%\"}"
  value="${value#\"}"
  value="${value%\'}"
  value="${value#\'}"
  printf '%s\n' "$value"
}

is_dangerous_rm_target() {
  local target="$1" recursive="$2" cwd="${3:-$REMOTE_ROOT}" project_root autodl_tmp
  target="$(strip_token_quotes "$target")"
  [ -n "$target" ] || return 1

  project_root="${REMOTE_ROOT%/}"
  autodl_tmp="/root/autodl-tmp"

  case "$target" in
    "\$REMOTE_ROOT"|"\${REMOTE_ROOT}"|"\$PWD"|"\${PWD}") return 0 ;;
  esac

  [ "$target" = "/" ] && return 0
  [ "$target" = "/*" ] && return 0

  if [ "$recursive" = "true" ]; then
    case "$target" in
      "."|"./"|"./*"|"*"|"~"|"~/"|"~/*") return 0 ;;
    esac
  fi

  while [ "${target%/}" != "$target" ] && [ "$target" != "/" ]; do
    target="${target%/}"
  done

  if [ "$target" = "$project_root" ]; then
    return 0
  fi
  if [ "$target" = "$project_root/*" ]; then
    return 0
  fi
  if [ "$target" = "$autodl_tmp" ] || [ "$target" = "$autodl_tmp/*" ]; then
    return 0
  fi
  if [ "$recursive" = "true" ] && [ "$target" = "$cwd" ]; then
    return 0
  fi
  return 1
}

contains_dangerous_rm() {
  local cmd="$1" cwd="${2:-$REMOTE_ROOT}" line token recursive
  while IFS= read -r line; do
    set -- $line
    while [ $# -gt 0 ]; do
      token="$(strip_token_quotes "$1")"
      case "$token" in
        sudo|command|builtin|nohup) shift ;;
        env) shift; while [ $# -gt 0 ]; do case "$1" in *=*) shift ;; *) break ;; esac; done ;;
        *=*) shift ;;
        *) break ;;
      esac
    done
    token="$(strip_token_quotes "${1:-}")"
    [ "${token##*/}" = "rm" ] || continue
    shift
    recursive=false
    while [ $# -gt 0 ]; do
      token="$1"
      shift
      case "$token" in
        --) break ;;
        --*) continue ;;
        -*) case "$token" in *r*|*R*) recursive=true ;; esac; continue ;;
      esac
      is_dangerous_rm_target "$token" "$recursive" "$cwd" && return 0
    done
    while [ $# -gt 0 ]; do
      token="$1"
      shift
      is_dangerous_rm_target "$token" "$recursive" "$cwd" && return 0
    done
  done <<EOF
$(printf '%s\n' "$cmd" | sed 's/[;&|]/\
/g')
EOF
  return 1
}

contains_dangerous_system_command() {
  local cmd="$1" line token command_name
  while IFS= read -r line; do
    set -- $line
    while [ $# -gt 0 ]; do
      token="$(strip_token_quotes "$1")"
      case "$token" in
        sudo|command|builtin|nohup) shift ;;
        env) shift; while [ $# -gt 0 ]; do case "$1" in *=*) shift ;; *) break ;; esac; done ;;
        *=*) shift ;;
        *) break ;;
      esac
    done
    [ $# -gt 0 ] || continue
    token="$(strip_token_quotes "$1")"
    command_name="${token##*/}"
    case "$command_name" in
      shutdown|reboot|poweroff|halt|mkfs|mkfs.*)
        return 0
        ;;
      dd)
        shift
        while [ $# -gt 0 ]; do
          token="$(strip_token_quotes "$1")"
          case "$token" in if=*) return 0 ;; esac
          shift
        done
        ;;
    esac
  done <<EOF
$(printf '%s\n' "$cmd" | sed 's/[;&|]/\
/g')
EOF
  return 1
}

dangerous_command_check() {
  local cmd="$1" cwd="${2:-$REMOTE_ROOT}"
  contains_dangerous_system_command "$cmd" && return 1
  contains_dangerous_rm "$cmd" "$cwd" && return 1
  return 0
}

cmd_account_add() {
  local name="" target="" host="" user="" port="22" key="" auth="prompt" default_remote="" force=false
  [ $# -gt 0 ] || die "account add requires a name"
  name="$1"
  shift
  valid_name "$name" || die "Invalid account name: $name"
  while [ $# -gt 0 ]; do
    case "$1" in
      --target) target="$2"; shift 2 ;;
      --host) host="$2"; shift 2 ;;
      --user) user="$2"; shift 2 ;;
      --port) port="$2"; shift 2 ;;
      --key) key="$2"; shift 2 ;;
      --auth) auth="$2"; shift 2 ;;
      --default-remote) default_remote="$2"; shift 2 ;;
      --force) force=true; shift ;;
      *) die "unknown account add option: $1" ;;
    esac
  done

  if [ -z "$target" ]; then
    if [ -z "$host" ] && [ -t 0 ]; then
      printf 'host: '
      read -r host
    fi
    if [ -z "$user" ] && [ -t 0 ]; then
      printf 'user [root]: '
      read -r user
      user="${user:-root}"
    fi
    [ -n "$host" ] || die "account add requires --target or --host."
    [ -n "$user" ] || user="root"
    target="$user@$host"
  fi

  case "$auth" in
    prompt|keychain|ssh-key) ;;
    *) die "--auth must be prompt, keychain, or ssh-key" ;;
  esac
  [ -z "$default_remote" ] || validate_remote_root "$default_remote"
  [ "$auth" != "ssh-key" ] || [ -n "$key" ] || die "--auth ssh-key requires --key"

  local path
  path="$(account_path "$name")"
  [ ! -f "$path" ] || [ "$force" = "true" ] || die "Account already exists: $name. Use --force to overwrite."
  cat > "$path" <<EOF
TARGET="$target"
PORT="$port"
KEY="$key"
AUTH="$auth"
DEFAULT_REMOTE="$default_remote"
EOF
  chmod 600 "$path"
  info "Saved account: $name"
}

cmd_account_list() {
  ensure_app_dirs
  local seen=false file name
  if ls "$ACCOUNTS_DIR"/*.conf >/dev/null 2>&1; then
    for file in "$ACCOUNTS_DIR"/*.conf; do
      seen=true
      name="$(basename "$file" .conf)"
      if [ "$(default_account 2>/dev/null || true)" = "$name" ]; then
        printf '* %s\n' "$name"
      else
        printf '  %s\n' "$name"
      fi
    done
  fi
  [ "$seen" = "true" ] || info "No accounts saved."
}

cmd_account_show() {
  [ $# -gt 0 ] || die "account show requires a name"
  load_account "$1"
  info "name=$ACCOUNT_NAME"
  info "target=$ACCOUNT_TARGET"
  info "port=$ACCOUNT_PORT"
  info "key=$ACCOUNT_KEY"
  info "auth=$ACCOUNT_AUTH"
  info "default_remote=$ACCOUNT_DEFAULT_REMOTE"
}

cmd_account_use() {
  [ $# -gt 0 ] || die "account use requires a name"
  load_account "$1"
  ensure_app_dirs
  printf '%s\n' "$ACCOUNT_NAME" > "$DEFAULT_ACCOUNT_FILE"
  info "Default account: $ACCOUNT_NAME"
}

cmd_account_test() {
  local name="${1:-}"
  if [ -z "$name" ]; then
    name="$(default_account)" || die "No default account. Run 'autodl-remote account use <name>'."
  fi
  load_account "$name"
  info "Testing $ACCOUNT_NAME -> $ACCOUNT_TARGET:$ACCOUNT_PORT"
  ssh_capture "printf 'host=' && hostname && printf 'pwd=' && pwd && printf 'rsync=' && { command -v rsync || true; }"
}

cmd_account_password_save() {
  [ $# -gt 0 ] || die "account password-save requires a name"
  load_account "$1"
  command -v security >/dev/null 2>&1 || die "macOS security command is not available."
  local password=""
  if [ -n "${AUTODL_REMOTE_PASSWORD:-}" ]; then
    password="$AUTODL_REMOTE_PASSWORD"
  else
    [ -t 0 ] || die "Set AUTODL_REMOTE_PASSWORD or run from an interactive terminal."
    printf 'password for %s: ' "$ACCOUNT_NAME" >&2
    stty -echo
    read -r password
    stty echo
    printf '\n' >&2
  fi
  [ -n "$password" ] || die "Empty password not saved."
  security add-generic-password -U -a "$ACCOUNT_NAME" -s "$KEYCHAIN_SERVICE" -w "$password" >/dev/null
  local path
  path="$(account_path "$ACCOUNT_NAME")"
  if [ ! -f "$path" ]; then
    local add_args=("$ACCOUNT_NAME" --target "$ACCOUNT_TARGET" --port "$ACCOUNT_PORT" --auth keychain --default-remote "$ACCOUNT_DEFAULT_REMOTE" --force)
    [ -n "$ACCOUNT_KEY" ] && add_args+=(--key "$ACCOUNT_KEY")
    cmd_account_add "${add_args[@]}" >/dev/null
  else
    awk -F= 'BEGIN{done=0} $1=="AUTH"{print "AUTH=\"keychain\""; done=1; next} {print} END{if(!done) print "AUTH=\"keychain\""}' "$path" > "$path.tmp"
    mv "$path.tmp" "$path"
    chmod 600 "$path"
  fi
  info "Saved password in macOS Keychain for account: $ACCOUNT_NAME"
}

cmd_account_password_delete() {
  [ $# -gt 0 ] || die "account password-delete requires a name"
  load_account "$1"
  command -v security >/dev/null 2>&1 || die "macOS security command is not available."
  security delete-generic-password -a "$ACCOUNT_NAME" -s "$KEYCHAIN_SERVICE" >/dev/null 2>&1 || true
  info "Deleted Keychain password for account: $ACCOUNT_NAME"
}

cmd_account() {
  [ $# -gt 0 ] || die "account requires a subcommand"
  local sub="$1"
  shift
  case "$sub" in
    add) cmd_account_add "$@" ;;
    list|ls) cmd_account_list "$@" ;;
    show) cmd_account_show "$@" ;;
    use) cmd_account_use "$@" ;;
    test) cmd_account_test "$@" ;;
    password-save) cmd_account_password_save "$@" ;;
    password-delete) cmd_account_password_delete "$@" ;;
    *) die "unknown account command: $sub" ;;
  esac
}

cmd_bind() {
  local account="" remote="" force=false
  while [ $# -gt 0 ]; do
    case "$1" in
      --account) account="$2"; shift 2 ;;
      --remote) remote="$2"; shift 2 ;;
      --force) force=true; shift ;;
      *) die "unknown bind option: $1" ;;
    esac
  done
  if [ -z "$account" ]; then
    account="$(default_account)" || die "bind requires --account or a default account."
  fi
  load_account "$account"
  [ -n "$remote" ] || remote="$ACCOUNT_DEFAULT_REMOTE"
  [ -n "$remote" ] || die "bind requires --remote."
  remote="${remote%/}"
  validate_remote_root "$remote"
  [ ! -f "$CONFIG_FILE" ] || [ "$force" = "true" ] || die "$CONFIG_FILE already exists. Use --force to overwrite."
  cat > "$CONFIG_FILE" <<EOF
ACCOUNT="$ACCOUNT_NAME"
REMOTE_ROOT="$remote"
EOF
  mkdir -p "$HISTORY_DIR"
  info "Bound $(pwd) to $ACCOUNT_NAME:$remote"
}

cmd_doctor() {
  load_project
  info "Config: $CONFIG_PATH"
  info "Local root: $PROJECT_ROOT"
  info "Account: $ACCOUNT_NAME"
  info "Target: $ACCOUNT_TARGET"
  info "Port: $ACCOUNT_PORT"
  info "Remote root: $REMOTE_ROOT"
  info "Local ssh: $(command -v ssh || echo MISSING)"
  info "Local rsync: $(command -v rsync || echo MISSING)"
  ssh_capture "printf 'host=' && hostname && printf 'pwd=' && pwd && printf 'remote_root=' && { test -d $(shell_quote "$REMOTE_ROOT") && echo exists || echo missing; } && printf 'rsync=' && { command -v rsync || true; } && command -v nvidia-smi >/dev/null 2>&1 && nvidia-smi --query-gpu=name,memory.total --format=csv,noheader || true"
}

cmd_exec() {
  load_project
  local detach=false cwd="" cwd_arg="" name="" allow_dangerous=false script="" stdin_mode=false remote_script=""
  local account_override="" remote_override="" model="" tags="" purpose="" stage="" outputs=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --account) account_override="$2"; shift 2 ;;
      --remote) remote_override="$2"; shift 2 ;;
      --detach) detach=true; shift ;;
      --cwd) cwd_arg="$2"; shift 2 ;;
      --name) name="$2"; shift 2 ;;
      --model) model="$2"; shift 2 ;;
      --tag) tags="$(append_csv "$tags" "$2")"; shift 2 ;;
      --purpose) purpose="$2"; shift 2 ;;
      --stage) stage="$2"; shift 2 ;;
      --output) outputs="$(append_csv "$outputs" "$2")"; shift 2 ;;
      --script) script="$2"; shift 2 ;;
      --stdin) stdin_mode=true; shift ;;
      --allow-dangerous) allow_dangerous=true; shift ;;
      --) shift; break ;;
      *) break ;;
    esac
  done
  [ "$stdin_mode" != "true" ] || [ -z "$script" ] || die "Use either --script or --stdin, not both."
  apply_context_override "$account_override" "$remote_override"
  cwd="$REMOTE_ROOT"
  [ -z "$cwd_arg" ] || cwd="$(remote_join "$cwd_arg")"

  local cmd="" tmp_name result pid status_path remote_cmd detach_rc
  if [ -n "$script" ]; then
    local local_script
    local_script="$(local_join "$script")"
    tmp_name="$(date +%Y%m%d-%H%M%S)-$(basename "$script" | sed 's/[^A-Za-z0-9_.-]/-/g')"
    remote_script="$REMOTE_ROOT/.autodl-remote/tmp/$tmp_name"
    if [ "$ACCOUNT_AUTH" = "keychain" ]; then
      upload_local_file "$local_script" "$remote_script" || return 1
    else
      upload_file_via_ssh "$local_script" "$remote_script" || return 1
    fi
    if [ $# -gt 0 ]; then
      cmd="$* $(shell_quote "$remote_script")"
    else
      cmd="bash $(shell_quote "$remote_script")"
    fi
  elif [ "$stdin_mode" = "true" ]; then
    [ $# -gt 0 ] || die "exec --stdin requires a command after --, for example: exec --stdin -- bash"
    tmp_name="$(date +%Y%m%d-%H%M%S)-stdin.sh"
    remote_script="$REMOTE_ROOT/.autodl-remote/tmp/$tmp_name"
    if [ "$ACCOUNT_AUTH" = "keychain" ]; then
      local tmp_local
      tmp_local="$(mktemp "${TMPDIR:-/tmp}/autodl-remote-stdin.XXXXXX")" || die "mktemp failed"
      cat > "$tmp_local"
      upload_local_file "$tmp_local" "$remote_script" || { rm -f "$tmp_local"; return 1; }
      rm -f "$tmp_local"
    else
      upload_stdin_to_remote "$remote_script" || return 1
    fi
    cmd="$* < $(shell_quote "$remote_script")"
  else
    [ $# -gt 0 ] || die "exec requires a command"
    cmd="$*"
  fi

  if [ "$allow_dangerous" != "true" ]; then
    dangerous_command_check "$cmd" "$cwd" || die "Dangerous remote command blocked. Re-run with --allow-dangerous after explicit approval."
  fi
  [ -n "$name" ] || name="exec-$(date +%Y%m%d-%H%M%S)"
  name="$(sanitize_name "$name")"
  local log="$REMOTE_ROOT/.autodl-remote/logs/$name.log"
  status_path="$REMOTE_ROOT/.autodl-remote/jobs/$name.status"
  info "log=$log"
  if [ "$detach" = "true" ]; then
    local runner runner_local
    runner="$REMOTE_ROOT/.autodl-remote/tmp/$name.runner.sh"
    runner_local="$(mktemp "${TMPDIR:-/tmp}/autodl-remote-runner.XXXXXX")" || die "mktemp failed"
    cat > "$runner_local" <<EOF
#!/usr/bin/env bash
set +e
started_at=\$(date +%Y-%m-%dT%H:%M:%S%z)
pid=\$BASHPID
printf 'status=running\npid=%s\nstarted_at=%s\nlog=%s\ncwd=%s\n' "\$pid" "\$started_at" $(shell_quote "$log") $(shell_quote "$cwd") > $(shell_quote "$status_path")
cd $(shell_quote "$cwd") && bash -lc $(shell_quote "$cmd") > $(shell_quote "$log") 2>&1
rc=\$?
finished_at=\$(date +%Y-%m-%dT%H:%M:%S%z)
printf 'status=exited\npid=%s\nstarted_at=%s\nfinished_at=%s\nexit_code=%s\nlog=%s\ncwd=%s\n' "\$pid" "\$started_at" "\$finished_at" "\$rc" $(shell_quote "$log") $(shell_quote "$cwd") > $(shell_quote "$status_path")
exit "\$rc"
EOF
    upload_local_file "$runner_local" "$runner" || { rm -f "$runner_local"; return 1; }
    rm -f "$runner_local"
    remote_cmd="mkdir -p $(shell_quote "$(dirname "$log")") $(shell_quote "$(dirname "$status_path")") && chmod +x $(shell_quote "$runner") && if command -v setsid >/dev/null 2>&1; then setsid bash $(shell_quote "$runner") < /dev/null > /dev/null 2>&1 & else nohup bash $(shell_quote "$runner") < /dev/null > /dev/null 2>&1 & fi; printf 'pid=%s\nlog=%s\nstatus=%s\n' \"\$!\" $(shell_quote "$log") $(shell_quote "$status_path")"
    result="$(ssh_capture "bash -lc $(shell_quote "$remote_cmd")" 2>&1)"
    detach_rc=$?
    printf '%s\n' "$result"
    [ "$detach_rc" -eq 0 ] || return "$detach_rc"
    pid="$(printf '%s\n' "$result" | awk -F= '$1=="pid"{print $2; exit}')"
    [ -n "$pid" ] || die "Remote detach did not return a pid."
    write_job "$name" "$pid" "$log" "$status_path" "$cwd" "$cmd" "$model" "$tags" "$purpose" "$stage" "$outputs"
    write_history exec-detach "$cmd log=$log"
  else
    local inner rc
    inner="set -o pipefail; ( $cmd ) 2>&1 | tee $(shell_quote "$log"); exit \${PIPESTATUS[0]}"
    ssh_run "mkdir -p $(shell_quote "$(dirname "$log")") && cd $(shell_quote "$cwd") && bash -lc $(shell_quote "$inner")"
    rc=$?
    write_history exec "$cmd rc=$rc log=$log"
    return "$rc"
  fi
}

cmd_put() {
  load_project
  local dry_run=false delete=false account_override="" remote_override=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --account) account_override="$2"; shift 2 ;;
      --remote) remote_override="$2"; shift 2 ;;
      --dry-run) dry_run=true; shift ;;
      --delete) delete=true; shift ;;
      --) shift; break ;;
      *) break ;;
    esac
  done
  apply_context_override "$account_override" "$remote_override"
  [ $# -ge 1 ] || die "put requires <local-path> [remote-path]"
  local local_arg="$1" remote_arg="${2:-}" local_path remote_path
  local_path="$(local_join "$local_arg")"
  [ -e "$local_path" ] || die "Local path does not exist: $local_arg"
  if [ -z "$remote_arg" ]; then
    remote_arg="$(remote_rel_for_local "$local_path")"
  fi
  remote_path="$(remote_join "$remote_arg")"
  ensure_remote_dir "$(dirname "$remote_path")"
  if command -v rsync >/dev/null 2>&1 && remote_has_rsync; then
    local args=(-az --human-readable -e "$(rsync_ssh_command)")
    [ "$dry_run" = "true" ] && args+=(--dry-run)
    [ "$delete" = "true" ] && args+=(--delete)
    if [ -d "$local_path" ]; then
      run_transport rsync "${args[@]}" "$local_path/" "$ACCOUNT_TARGET:$remote_path/"
    else
      run_transport rsync "${args[@]}" "$local_path" "$ACCOUNT_TARGET:$remote_path"
    fi
  else
    [ "$dry_run" != "true" ] || die "dry-run requires rsync."
    scp_common_args
    if [ -d "$local_path" ]; then
      run_transport scp -r "${SCP_ARGS[@]}" "$local_path" "$ACCOUNT_TARGET:$remote_path"
    else
      run_transport scp "${SCP_ARGS[@]}" "$local_path" "$ACCOUNT_TARGET:$remote_path"
    fi
  fi
  write_history put "$local_arg -> $remote_path"
}

cmd_get() {
  load_project
  local dry_run=false account_override="" remote_override=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --account) account_override="$2"; shift 2 ;;
      --remote) remote_override="$2"; shift 2 ;;
      --dry-run) dry_run=true; shift ;;
      --) shift; break ;;
      *) break ;;
    esac
  done
  apply_context_override "$account_override" "$remote_override"
  [ $# -ge 1 ] || die "get requires <remote-path> [local-path]"
  local remote_arg="$1" local_arg="${2:-}" remote_path local_path kind
  remote_path="$(remote_join "$remote_arg")"
  if [ -z "$local_arg" ]; then
    case "$remote_arg" in
      /*) local_arg="$(basename "$remote_arg")" ;;
      *) local_arg="$remote_arg" ;;
    esac
  fi
  local_path="$(local_join "$local_arg")"
  mkdir -p "$(dirname "$local_path")"
  kind="$(ssh_capture "if [ -d $(shell_quote "$remote_path") ]; then echo dir; elif [ -f $(shell_quote "$remote_path") ]; then echo file; else echo missing; fi")"
  [ "$kind" != "missing" ] || die "Remote path does not exist: $remote_arg"
  if command -v rsync >/dev/null 2>&1 && remote_has_rsync; then
    local args=(-az --human-readable -e "$(rsync_ssh_command)")
    [ "$dry_run" = "true" ] && args+=(--dry-run)
    if [ "$kind" = "dir" ]; then
      mkdir -p "$local_path"
      run_transport rsync "${args[@]}" "$ACCOUNT_TARGET:$remote_path/" "$local_path/"
    else
      run_transport rsync "${args[@]}" "$ACCOUNT_TARGET:$remote_path" "$local_path"
    fi
  else
    [ "$dry_run" != "true" ] || die "dry-run requires rsync."
    scp_common_args
    if [ "$kind" = "dir" ]; then
      run_transport scp -r "${SCP_ARGS[@]}" "$ACCOUNT_TARGET:$remote_path" "$local_path"
    else
      run_transport scp "${SCP_ARGS[@]}" "$ACCOUNT_TARGET:$remote_path" "$local_path"
    fi
  fi
  write_history get "$remote_path -> $local_arg"
}

cmd_tree() {
  load_project
  local path="." depth=3 limit=500 account_override="" remote_override=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --account) account_override="$2"; shift 2 ;;
      --remote) remote_override="$2"; shift 2 ;;
      --depth) depth="$2"; shift 2 ;;
      --limit) limit="$2"; shift 2 ;;
      --) shift; break ;;
      -*) die "unknown tree option: $1" ;;
      *) path="$1"; shift ;;
    esac
  done
  apply_context_override "$account_override" "$remote_override"
  local remote_path
  remote_path="$(remote_join "$path")"
  ssh_capture "cd $(shell_quote "$remote_path") && { find . -maxdepth $depth | sed 's#^./##' | sort | head -n $limit; true; }"
}

cmd_ls() {
  load_project
  local account_override="" remote_override=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --account) account_override="$2"; shift 2 ;;
      --remote) remote_override="$2"; shift 2 ;;
      --) shift; break ;;
      -*) die "unknown ls option: $1" ;;
      *) break ;;
    esac
  done
  apply_context_override "$account_override" "$remote_override"
  local path="${1:-.}"
  ssh_run "ls -lah $(shell_quote "$(remote_join "$path")")"
}

cmd_cat() {
  load_project
  local lines=200 account_override="" remote_override=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --account) account_override="$2"; shift 2 ;;
      --remote) remote_override="$2"; shift 2 ;;
      --lines) lines="$2"; shift 2 ;;
      --) shift; break ;;
      *) break ;;
    esac
  done
  apply_context_override "$account_override" "$remote_override"
  [ $# -gt 0 ] || die "cat requires a path"
  ssh_run "sed -n '1,${lines}p' $(shell_quote "$(remote_join "$1")")"
}

cmd_tail() {
  load_project
  local lines=120 follow=false account_override="" remote_override=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --account) account_override="$2"; shift 2 ;;
      --remote) remote_override="$2"; shift 2 ;;
      --lines) lines="$2"; shift 2 ;;
      --follow|-f) follow=true; shift ;;
      --) shift; break ;;
      *) break ;;
    esac
  done
  apply_context_override "$account_override" "$remote_override"
  [ $# -gt 0 ] || die "tail requires a path"
  local flag=""
  [ "$follow" = "true" ] && flag="-f"
  ssh_run "tail -n $lines $flag $(shell_quote "$(remote_join "$1")")"
}

cmd_job_list() {
  load_project
  local dir file name pid started log command seen=false
  dir="$(jobs_dir)"
  mkdir -p "$dir"
  if ls "$dir"/*.conf >/dev/null 2>&1; then
    printf '%-24s %-10s %-24s %s\n' "name" "pid" "started_at" "log"
    for file in "$dir"/*.conf; do
      seen=true
      name="$(job_get "$file" NAME)"
      pid="$(job_get "$file" PID)"
      started="$(job_get "$file" STARTED_AT)"
      log="$(job_get "$file" LOG_PATH)"
      command="$(job_get "$file" COMMAND)"
      printf '%-24s %-10s %-24s %s\n' "$name" "$pid" "$started" "$log"
      [ -n "$command" ] && printf '  command: %s\n' "$command"
    done
  fi
  [ "$seen" = "true" ] || info "No jobs recorded."
}

cmd_job_status() {
  load_project
  [ $# -gt 0 ] || die "job status requires a name"
  local name file pid log status_path cwd command remote_status rc
  name="$(sanitize_name "$1")"
  file="$(job_path "$name")"
  [ -f "$file" ] || die "Job not found: $name"
  pid="$(job_get "$file" PID)"
  log="$(job_get "$file" LOG_PATH)"
  status_path="$(job_get "$file" STATUS_PATH)"
  cwd="$(job_get "$file" CWD)"
  command="$(job_get "$file" COMMAND)"
  [ -n "$pid" ] || die "Job has no recorded pid: $name"
  apply_job_context "$file"

  info "name=$name"
  info "account=$ACCOUNT_NAME"
  info "remote_root=$REMOTE_ROOT"
  info "pid=$pid"
  info "cwd=$cwd"
  info "log=$log"
  info "status_path=$status_path"
  info "command=$command"
  remote_status="$(ssh_capture "if [ -f $(shell_quote "$status_path") ]; then cat $(shell_quote "$status_path"); elif kill -0 $(shell_quote "$pid") 2>/dev/null; then printf 'status=running\npid=%s\n' $(shell_quote "$pid"); else printf 'status=unknown\npid=%s\n' $(shell_quote "$pid"); fi; if kill -0 $(shell_quote "$pid") 2>/dev/null; then echo alive=yes; else echo alive=no; fi" 2>&1)"
  rc=$?
  if [ "$rc" -eq 0 ]; then
    printf '%s\n' "$remote_status"
  else
    info "remote_status=unreachable"
    printf '%s\n' "$remote_status" >&2
    return "$rc"
  fi
}

cmd_job_tail() {
  load_project
  local lines=120 follow=false
  while [ $# -gt 0 ]; do
    case "$1" in
      --lines) lines="$2"; shift 2 ;;
      --follow|-f) follow=true; shift ;;
      --) shift; break ;;
      *) break ;;
    esac
  done
  [ $# -gt 0 ] || die "job tail requires a name"
  local name file log flag=""
  name="$(sanitize_name "$1")"
  file="$(job_path "$name")"
  [ -f "$file" ] || die "Job not found: $name"
  log="$(job_get "$file" LOG_PATH)"
  apply_job_context "$file"
  [ "$follow" = "true" ] && flag="-f"
  ssh_run "tail -n $lines $flag $(shell_quote "$log")"
}

cmd_job() {
  [ $# -gt 0 ] || die "job requires a subcommand"
  local sub="$1"
  shift
  case "$sub" in
    list|ls) cmd_job_list "$@" ;;
    status) cmd_job_status "$@" ;;
    tail) cmd_job_tail "$@" ;;
    *) die "unknown job command: $sub" ;;
  esac
}

cmd_run_list() {
  load_project
  local dir file name account remote model stage tags started status seen=false
  dir="$(jobs_dir)"
  mkdir -p "$dir"
  if ls "$dir"/*.conf >/dev/null 2>&1; then
    printf '%-24s %-14s %-12s %-12s %-16s %-20s %s\n' "run" "account" "status" "model" "stage" "started_at" "tags"
    for file in "$dir"/*.conf; do
      seen=true
      name="$(job_get "$file" NAME)"
      account="$(job_get "$file" ACCOUNT)"
      remote="$(job_get "$file" REMOTE_ROOT)"
      model="$(job_get "$file" MODEL)"
      stage="$(job_get "$file" STAGE)"
      tags="$(job_get "$file" TAGS)"
      started="$(job_get "$file" STARTED_AT)"
      [ -n "$account" ] || account="${PROJECT_BOUND_ACCOUNT:-$PROJECT_ACCOUNT}"
      [ -n "$remote" ] || remote="${PROJECT_BOUND_REMOTE_ROOT:-$REMOTE_ROOT}"
      status="$(job_remote_status_summary "$file")"
      printf '%-24s %-14s %-12s %-12s %-16s %-20s %s\n' "$name" "$account" "$status" "${model:--}" "${stage:--}" "$started" "${tags:--}"
    done
  fi
  [ "$seen" = "true" ] || info "No runs recorded."
}

cmd_run_note() {
  load_project
  [ $# -gt 0 ] || die "run note requires a run name"
  local name file model="" tags="" purpose="" stage="" outputs=""
  name="$(sanitize_name "$1")"
  shift
  file="$(job_path "$name")"
  [ -f "$file" ] || die "Run not found: $name"
  while [ $# -gt 0 ]; do
    case "$1" in
      --model) model="$2"; shift 2 ;;
      --tag) tags="$(append_csv "$tags" "$2")"; shift 2 ;;
      --purpose) purpose="$2"; shift 2 ;;
      --stage) stage="$2"; shift 2 ;;
      --output) outputs="$(append_csv "$outputs" "$2")"; shift 2 ;;
      *) die "unknown run note option: $1" ;;
    esac
  done
  [ -z "$model" ] || config_set_in_file "$file" MODEL "$model"
  if [ -n "$tags" ]; then
    local existing_tags
    existing_tags="$(job_get "$file" TAGS)"
    [ -n "$existing_tags" ] && tags="$(append_csv "$existing_tags" "$tags")"
    config_set_in_file "$file" TAGS "$tags"
  fi
  [ -z "$purpose" ] || config_set_in_file "$file" PURPOSE "$purpose"
  [ -z "$stage" ] || config_set_in_file "$file" STAGE "$stage"
  if [ -n "$outputs" ]; then
    local existing_outputs
    existing_outputs="$(job_get "$file" OUTPUTS)"
    [ -n "$existing_outputs" ] && outputs="$(append_csv "$existing_outputs" "$outputs")"
    config_set_in_file "$file" OUTPUTS "$outputs"
  fi
  info "Updated run: $name"
}

cmd_run_submit() {
  local args=(--detach) uploads=() account_override="" remote_override=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --account) account_override="$2"; args+=("$1" "$2"); shift 2 ;;
      --remote) remote_override="$2"; args+=("$1" "$2"); shift 2 ;;
      --sync-up) uploads+=("$2"); shift 2 ;;
      --) shift; break ;;
      *) args+=("$1"); shift ;;
    esac
  done
  [ $# -gt 0 ] || die "run submit requires a command after --"
  local path
  for path in "${uploads[@]}"; do
    local put_args=()
    [ -z "$account_override" ] || put_args+=(--account "$account_override")
    [ -z "$remote_override" ] || put_args+=(--remote "$remote_override")
    cmd_put "${put_args[@]}" "$path"
  done
  cmd_exec "${args[@]}" -- "$@"
}

cmd_run() {
  [ $# -gt 0 ] || die "run requires a subcommand"
  local sub="$1"
  shift
  case "$sub" in
    submit) cmd_run_submit "$@" ;;
    list|ls) cmd_run_list "$@" ;;
    status) cmd_job_status "$@" ;;
    tail) cmd_job_tail "$@" ;;
    note) cmd_run_note "$@" ;;
    *) die "unknown run command: $sub" ;;
  esac
}

cmd_fleet_create() {
  load_project
  [ $# -gt 0 ] || die "fleet create requires a name"
  local name dir
  name="$1"
  valid_name "$name" || die "Invalid fleet name: $name"
  dir="$(fleet_dir "$name")"
  mkdir -p "$dir"
  info "Created fleet: $name"
}

cmd_fleet_add() {
  load_project
  [ $# -ge 2 ] || die "fleet add requires <fleet> <device>"
  local fleet="$1" device="$2" account="$PROJECT_ACCOUNT" remote="$REMOTE_ROOT" tags="" file
  shift 2
  while [ $# -gt 0 ]; do
    case "$1" in
      --account) account="$2"; shift 2 ;;
      --remote) remote="$2"; shift 2 ;;
      --tags) tags="$2"; shift 2 ;;
      *) die "unknown fleet add option: $1" ;;
    esac
  done
  load_account "$account"
  [ -n "$remote" ] || remote="$ACCOUNT_DEFAULT_REMOTE"
  [ -n "$remote" ] || die "fleet add requires --remote or an account default remote."
  remote="${remote%/}"
  validate_remote_root "$remote"
  mkdir -p "$(fleet_dir "$fleet")"
  file="$(fleet_device_path "$fleet" "$device")"
  cat > "$file" <<EOF
FLEET="$(config_quote "$fleet")"
NAME="$(config_quote "$device")"
ACCOUNT="$(config_quote "$account")"
REMOTE_ROOT="$(config_quote "$remote")"
TAGS="$(config_quote "$tags")"
ADDED_AT="$(date +%Y-%m-%dT%H:%M:%S%z)"
EOF
  info "Added $device -> $account:$remote to fleet $fleet"
}

cmd_fleet_list() {
  load_project
  local root fleet_dir file fleet device account remote tags seen=false
  root="$(fleet_root)"
  mkdir -p "$root"
  if [ -n "$(find "$root" -mindepth 2 -maxdepth 2 -name '*.conf' -print -quit 2>/dev/null)" ]; then
    printf '%-16s %-18s %-14s %-34s %s\n' "fleet" "device" "account" "remote_root" "tags"
    while IFS= read -r file; do
      [ -n "$file" ] || continue
      seen=true
      fleet="$(device_get "$file" FLEET)"
      device="$(device_get "$file" NAME)"
      account="$(device_get "$file" ACCOUNT)"
      remote="$(device_get "$file" REMOTE_ROOT)"
      tags="$(device_get "$file" TAGS)"
      printf '%-16s %-18s %-14s %-34s %s\n' "$fleet" "$device" "$account" "$remote" "${tags:--}"
    done <<EOF
$(find "$root" -mindepth 2 -maxdepth 2 -name '*.conf' | sort)
EOF
  fi
  [ "$seen" = "true" ] || info "No fleets recorded."
}

latest_run_for_device() {
  local account="$1" remote="$2" dir file name latest_name="" latest_started="" started job_account job_remote
  dir="$(jobs_dir)"
  if ls "$dir"/*.conf >/dev/null 2>&1; then
    for file in "$dir"/*.conf; do
      job_account="$(job_get "$file" ACCOUNT)"
      job_remote="$(job_get "$file" REMOTE_ROOT)"
      [ -n "$job_account" ] || job_account="${PROJECT_BOUND_ACCOUNT:-$PROJECT_ACCOUNT}"
      [ -n "$job_remote" ] || job_remote="${PROJECT_BOUND_REMOTE_ROOT:-$REMOTE_ROOT}"
      [ "$job_account" = "$account" ] || continue
      [ "$job_remote" = "$remote" ] || continue
      started="$(job_get "$file" STARTED_AT)"
      name="$(job_get "$file" NAME)"
      if [ -z "$latest_started" ] || [ "$started" \> "$latest_started" ]; then
        latest_started="$started"
        latest_name="$name"
      fi
    done
  fi
  printf '%s\n' "${latest_name:--}"
}

print_device_status() {
  local device="$1" account="$2" remote="$3" tags="$4" probe online host gpu disk current
  load_account "$account"
  REMOTE_ROOT="${remote%/}"
  validate_remote_root "$REMOTE_ROOT"
  probe="$(remote_probe)"
  online="$(kv_get "$probe" online)"
  host="$(kv_get "$probe" host)"
  gpu="$(kv_get "$probe" gpu)"
  disk="$(kv_get "$probe" disk)"
  current="$(latest_run_for_device "$account" "$REMOTE_ROOT")"
  printf '%-18s %-8s %-14s %-28s %-22s %-18s %s\n' "$device" "${online:-no}" "$account" "${gpu:--}" "${disk:--}" "$current" "${tags:--}"
  [ "${online:-no}" = "yes" ] || printf '  error: %s\n' "$(kv_get "$probe" error)"
  [ -n "$host" ] && printf '  host: %s remote: %s\n' "$host" "$REMOTE_ROOT"
}

cmd_fleet_status() {
  load_project
  local fleet="" file device account remote tags
  [ $# -gt 0 ] && fleet="$1"
  printf '%-18s %-8s %-14s %-28s %-22s %-18s %s\n' "device" "online" "account" "gpu" "disk" "current_run" "tags"
  if [ -z "$fleet" ]; then
    print_device_status "current" "$PROJECT_ACCOUNT" "$REMOTE_ROOT" "project"
    return 0
  fi
  [ -d "$(fleet_dir "$fleet")" ] || die "Fleet not found: $fleet"
  for file in "$(fleet_dir "$fleet")"/*.conf; do
    [ -f "$file" ] || continue
    device="$(device_get "$file" NAME)"
    account="$(device_get "$file" ACCOUNT)"
    remote="$(device_get "$file" REMOTE_ROOT)"
    tags="$(device_get "$file" TAGS)"
    print_device_status "$device" "$account" "$remote" "$tags"
  done
}

cmd_fleet() {
  [ $# -gt 0 ] || die "fleet requires a subcommand"
  local sub="$1"
  shift
  case "$sub" in
    create) cmd_fleet_create "$@" ;;
    add) cmd_fleet_add "$@" ;;
    list|ls) cmd_fleet_list "$@" ;;
    status) cmd_fleet_status "$@" ;;
    *) die "unknown fleet command: $sub" ;;
  esac
}

remote_log_tail() {
  local account="$1" remote="$2" log="$3" lines="$4" output rc
  [ -n "$log" ] || { printf '[log missing]\n'; return 0; }
  load_account "$account"
  REMOTE_ROOT="${remote%/}"
  validate_remote_root "$REMOTE_ROOT"
  output="$(ssh_capture "if [ -f $(shell_quote "$log") ]; then tail -n $lines $(shell_quote "$log"); else printf '[log missing] %s\n' $(shell_quote "$log"); fi" 2>&1)"
  rc=$?
  if [ "$rc" -eq 0 ]; then
    printf '%s\n' "$output"
  else
    printf '[log unavailable]\n%s\n' "$output"
  fi
}

dashboard_pct() {
  local pct
  pct="$(printf '%s\n' "$1" | awk 'match($0, /[0-9]+%/) { print substr($0, RSTART, RLENGTH - 1); exit }')"
  case "$pct" in
    ""|*[!0-9]*) pct=0 ;;
  esac
  [ "$pct" -gt 100 ] 2>/dev/null && pct=100
  printf '%s\n' "$pct"
}

dashboard_gpu_model() {
  local value="$1" model
  model="$(printf '%s\n' "$value" | sed -E 's/[[:space:]][0-9]+\/[0-9]+ MiB [0-9]+%$//')"
  [ -n "$model" ] || model="-"
  printf '%s\n' "$model"
}

dashboard_gpu_mem() {
  local value="$1" mem
  mem="$(printf '%s\n' "$value" | sed -nE 's/.* ([0-9]+\/[0-9]+ MiB) [0-9]+%$/\1/p')"
  [ -n "$mem" ] || mem="-"
  printf '%s\n' "$mem"
}

dashboard_status_class() {
  local online="$1" status="$2"
  if [ "${online:-no}" != "yes" ]; then
    printf 'offline\n'
    return 0
  fi
  case "$status" in
    running) printf 'training\n' ;;
    unreachable|failed|error) printf 'error\n' ;;
    *) printf 'idle\n' ;;
  esac
}

dashboard_status_label() {
  case "$1" in
    training) printf '训练中\n' ;;
    idle) printf '空闲\n' ;;
    error) printf '异常\n' ;;
    offline) printf '离线\n' ;;
    *) printf '%s\n' "$1" ;;
  esac
}

dashboard_job_in_scope() {
  local file="$1" scope_fleet="$2" account remote fleet_file fleet_account fleet_remote
  account="$(job_get "$file" ACCOUNT)"
  remote="$(job_get "$file" REMOTE_ROOT)"
  [ -n "$account" ] || account="${PROJECT_BOUND_ACCOUNT:-$PROJECT_ACCOUNT}"
  [ -n "$remote" ] || remote="${PROJECT_BOUND_REMOTE_ROOT:-$REMOTE_ROOT}"
  if [ -z "$scope_fleet" ]; then
    [ "$account" = "${PROJECT_BOUND_ACCOUNT:-$PROJECT_ACCOUNT}" ] && [ "$remote" = "${PROJECT_BOUND_REMOTE_ROOT:-$REMOTE_ROOT}" ]
    return $?
  fi
  for fleet_file in "$(fleet_dir "$scope_fleet")"/*.conf; do
    [ -f "$fleet_file" ] || continue
    fleet_account="$(device_get "$fleet_file" ACCOUNT)"
    fleet_remote="$(device_get "$fleet_file" REMOTE_ROOT)"
    if [ "$fleet_account" = "$account" ] && [ "$fleet_remote" = "$remote" ]; then
      return 0
    fi
  done
  return 1
}

latest_job_file_for_device() {
  local account="$1" remote="$2" dir file latest_file="" latest_started="" started job_account job_remote
  dir="$(jobs_dir)"
  if ls "$dir"/*.conf >/dev/null 2>&1; then
    for file in "$dir"/*.conf; do
      job_account="$(job_get "$file" ACCOUNT)"
      job_remote="$(job_get "$file" REMOTE_ROOT)"
      [ -n "$job_account" ] || job_account="${PROJECT_BOUND_ACCOUNT:-$PROJECT_ACCOUNT}"
      [ -n "$job_remote" ] || job_remote="${PROJECT_BOUND_REMOTE_ROOT:-$REMOTE_ROOT}"
      [ "$job_account" = "$account" ] || continue
      [ "$job_remote" = "$remote" ] || continue
      started="$(job_get "$file" STARTED_AT)"
      if [ -z "$latest_started" ] || [ "$started" \> "$latest_started" ]; then
        latest_started="$started"
        latest_file="$file"
      fi
    done
  fi
  printf '%s\n' "$latest_file"
}

dashboard_device_card() {
  local device="$1" account="$2" remote="$3" tags="$4" lines="$5"
  local probe online host gpu disk processes current_file current status status_class status_label
  local gpu_util gpu_model gpu_mem disk_pct log log_tail model stage purpose started card_id

  DASHBOARD_DEVICE_TOTAL=$((DASHBOARD_DEVICE_TOTAL + 1))
  load_account "$account"
  REMOTE_ROOT="${remote%/}"
  validate_remote_root "$REMOTE_ROOT"
  probe="$(remote_probe)"
  online="$(kv_get "$probe" online)"
  host="$(kv_get "$probe" host)"
  gpu="$(kv_get "$probe" gpu)"
  disk="$(kv_get "$probe" disk)"
  processes="$(kv_get "$probe" processes)"
  current_file="$(latest_job_file_for_device "$account" "$REMOTE_ROOT")"
  current="-"
  status="idle"
  log=""
  log_tail="[no recorded run]"
  model="-"
  stage="-"
  purpose=""
  started="-"
  if [ -n "$current_file" ]; then
    current="$(job_get "$current_file" NAME)"
    status="$(job_remote_status_summary "$current_file")"
    log="$(job_get "$current_file" LOG_PATH)"
    model="$(job_get "$current_file" MODEL)"
    stage="$(job_get "$current_file" STAGE)"
    purpose="$(job_get "$current_file" PURPOSE)"
    started="$(job_get "$current_file" STARTED_AT)"
    [ -n "$model" ] || model="-"
    [ -n "$stage" ] || stage="-"
    if [ "$lines" -gt 0 ]; then
      log_tail="$(remote_log_tail "$account" "$REMOTE_ROOT" "$log" "$lines")"
    else
      log_tail="[log hidden: --lines 0]"
    fi
  elif [ -n "$processes" ]; then
    log_tail="$processes"
  fi

  status_class="$(dashboard_status_class "$online" "$status")"
  status_label="$(dashboard_status_label "$status_class")"
  case "$status_class" in
    training) DASHBOARD_TRAINING_TOTAL=$((DASHBOARD_TRAINING_TOTAL + 1)) ;;
    idle) DASHBOARD_IDLE_TOTAL=$((DASHBOARD_IDLE_TOTAL + 1)) ;;
    error) DASHBOARD_ERROR_TOTAL=$((DASHBOARD_ERROR_TOTAL + 1)) ;;
    offline) DASHBOARD_OFFLINE_TOTAL=$((DASHBOARD_OFFLINE_TOTAL + 1)) ;;
  esac
  [ "${online:-no}" = "yes" ] && DASHBOARD_ONLINE_TOTAL=$((DASHBOARD_ONLINE_TOTAL + 1))

  gpu="${gpu:--}"
  disk="${disk:--}"
  gpu_util="$(dashboard_pct "$gpu")"
  disk_pct="$(dashboard_pct "$disk")"
  gpu_model="$(dashboard_gpu_model "$gpu")"
  gpu_mem="$(dashboard_gpu_mem "$gpu")"
  card_id="$(sanitize_name "${device}-${account}")"
  DASHBOARD_HEAT_CELLS="${DASHBOARD_HEAT_CELLS}<span class=\"heat-cell heat-${status_class}\" title=\"$(html_escape "$device · ${gpu_util}%")\" style=\"--v:${gpu_util}%\"></span>"

  printf '<article class="mc mc-%s" data-status="%s">\n' "$status_class" "$status_class"
  printf '<div class="mc-head"><div class="mc-head-l"><div class="mc-id"><span class="mc-bracket">[</span><span class="mc-id-text">%s</span><span class="mc-bracket">]</span></div><div class="mc-name">%s</div><div class="mc-sub"><span>%s</span><span class="sep">·</span><span>%s</span></div></div><div class="mc-head-r"><span class="st-badge"><span class="st-dot"></span>%s</span><div class="mc-uptime">%s</div></div></div>\n' \
    "$(html_escape "$device")" "$(html_escape "$account")" "$(html_escape "${host:--}")" "$(html_escape "${tags:--}")" "$(html_escape "$status_label")" "$(html_escape "${status:-unknown}")"
  printf '<div class="mc-agg"><div class="mc-agg-l"><span class="agg-k">GPU UTIL</span><span class="agg-v">%s<span class="pct-s">%%</span></span></div><div class="ubar-wrap"><div class="ubar-track"></div><div class="ubar-fill" style="width:%s%%"></div></div><div class="mc-agg-r">%s</div></div>\n' \
    "$(html_escape "$gpu_util")" "$(html_escape "$gpu_util")" "$(html_escape "$gpu_mem")"
  printf '<div class="gpu-row"><div class="gpu-row-head"><span class="gpu-tag">GPU</span><span class="gpu-model">%s</span><span class="gpu-util-pct">%s<span class="pct-s">%%</span></span></div><div class="gpu-row-meta"><span class="meta-cell"><span class="meta-k">DISK</span><span class="meta-v">%s</span><span class="meta-mini-bar"><span style="width:%s%%"></span></span></span><span class="meta-cell"><span class="meta-k">REMOTE</span><span class="meta-v">%s</span></span></div></div>\n' \
    "$(html_escape "$gpu_model")" "$(html_escape "$gpu_util")" "$(html_escape "$disk")" "$(html_escape "$disk_pct")" "$(html_escape "$REMOTE_ROOT")"
  printf '<div class="mc-task"><div class="task-row"><span class="task-arrow">▸</span><span class="task-name">%s</span></div><div class="task-meta">%s · %s · %s</div>' \
    "$(html_escape "$current")" "$(html_escape "$model")" "$(html_escape "$stage")" "$(html_escape "$started")"
  [ -n "$purpose" ] && printf '<div class="task-purpose">%s</div>' "$(html_escape "$purpose")"
  printf '</div>\n'
  printf '<div class="mc-term"><div class="term-bar"><span class="term-dot"></span><span class="term-bar-t">%s</span><span class="term-bar-eta">last %s</span></div><pre class="term-body" data-term-id="%s">%s</pre></div>\n' \
    "$(html_escape "${log:-processes}")" "$(html_escape "$lines")" "$(html_escape "$card_id")" "$(html_escape "$log_tail")"
  printf '</article>\n'
}

dashboard_device_cards() {
  local fleet="$1" lines="$2" device_file device account remote tags
  if [ -n "$fleet" ]; then
    for device_file in "$(fleet_dir "$fleet")"/*.conf; do
      [ -f "$device_file" ] || continue
      device="$(device_get "$device_file" NAME)"
      account="$(device_get "$device_file" ACCOUNT)"
      remote="$(device_get "$device_file" REMOTE_ROOT)"
      tags="$(device_get "$device_file" TAGS)"
      dashboard_device_card "$device" "$account" "$remote" "$tags" "$lines"
    done
  else
    dashboard_device_card "current" "$PROJECT_ACCOUNT" "$REMOTE_ROOT" "project" "$lines"
  fi
}

dashboard_run_tiles() {
  local scope_fleet="$1" dir file name account remote model stage started log purpose
  dir="$(jobs_dir)"
  printf '<section class="run-panel"><div class="sec-t"><span class="sec-t-l">─ RUNS</span><span class="sec-t-line"></span></div><div class="run-list">\n'
  if ls "$dir"/*.conf >/dev/null 2>&1; then
    for file in "$dir"/*.conf; do
      dashboard_job_in_scope "$file" "$scope_fleet" || continue
      DASHBOARD_RUN_TOTAL=$((DASHBOARD_RUN_TOTAL + 1))
      name="$(job_get "$file" NAME)"
      account="$(job_get "$file" ACCOUNT)"
      remote="$(job_get "$file" REMOTE_ROOT)"
      model="$(job_get "$file" MODEL)"
      stage="$(job_get "$file" STAGE)"
      started="$(job_get "$file" STARTED_AT)"
      log="$(job_get "$file" LOG_PATH)"
      purpose="$(job_get "$file" PURPOSE)"
      [ -n "$account" ] || account="${PROJECT_BOUND_ACCOUNT:-$PROJECT_ACCOUNT}"
      [ -n "$remote" ] || remote="${PROJECT_BOUND_REMOTE_ROOT:-$REMOTE_ROOT}"
      printf '<div class="run-chip"><div class="run-chip-h"><span>%s</span><span>%s</span></div><div class="run-chip-m">%s · %s · %s</div><div class="run-chip-f">%s</div><div class="run-chip-note">%s</div></div>\n' \
        "$(html_escape "$name")" "$(html_escape "${stage:--}")" "$(html_escape "$account")" "$(html_escape "${model:--}")" "$(html_escape "$started")" "$(html_escape "$log")" "$(html_escape "$purpose")"
    done
  fi
  if [ "$DASHBOARD_RUN_TOTAL" -eq 0 ]; then
    printf '<div class="empty">NO RUNS RECORDED</div>\n'
  fi
  printf '</div></section>\n'
}

dashboard_state_path() {
  local output="$1" dir base
  dir="$(dirname "$output")"
  base="$(basename "$output")"
  case "$base" in
    *.html) base="${base%.html}.state.js" ;;
    *) base="$base.state.js" ;;
  esac
  printf '%s/%s\n' "$dir" "$base"
}

js_string() {
  printf '"'
  printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
  printf '"'
}

base64_file_compact() {
  base64 < "$1" | tr -d '\n'
}

dashboard_css() {
  cat <<'EOF'
:root{--bg:#fdf6e3;--bg-2:#f3ead0;--card:#fffbef;--card-2:#f7efd5;--border:#e1d6a8;--border-2:#cdc295;--border-soft:#ebe1b8;--fg:#073642;--fg-dim:#586e75;--dim:#93a1a1;--muted:#93a1a1;--muted-strong:#657b83;--ok:#859900;--hot:#dc322f;--warm:#b58900;--cool:#268bd2;--err:#dc322f;--off:#93a1a1;--off-bg:#e1d6a8;--term-bg:#002b36;--term-fg:#93a1a1}*{box-sizing:border-box}html,body{margin:0;min-height:100%;background:var(--bg);color:var(--fg)}body{font-family:"JetBrains Mono","IBM Plex Mono",ui-monospace,SFMono-Regular,Menlo,monospace;-webkit-font-smoothing:antialiased;overflow-x:hidden}.app{min-height:100vh;background:radial-gradient(ellipse 1200px 600px at 50% -200px,rgba(133,153,0,.09),transparent 70%),linear-gradient(var(--bg),var(--bg-2));display:flex;flex-direction:column}.scanlines{position:fixed;inset:0;pointer-events:none;z-index:50;background-image:repeating-linear-gradient(to bottom,rgba(0,0,0,0) 0,rgba(0,0,0,0) 2px,rgba(0,0,0,.025) 3px,rgba(0,0,0,0) 4px);mix-blend-mode:multiply}.vignette{position:fixed;inset:0;pointer-events:none;z-index:49;box-shadow:inset 0 0 180px rgba(0,0,0,.08)}.topbar{position:sticky;top:0;z-index:30;background:rgba(253,246,227,.88);backdrop-filter:blur(10px) saturate(150%);border-bottom:1px solid var(--border);padding:14px 22px 0;display:grid;grid-template-columns:minmax(280px,1fr) minmax(420px,1.4fr) minmax(260px,1fr);grid-template-rows:auto auto;grid-template-areas:"l c r" "f f f";gap:16px 24px;align-items:center}.topbar-l{grid-area:l;display:flex;flex-direction:column;gap:6px}.topbar-c{grid-area:c;display:flex;justify-content:center}.topbar-r{grid-area:r;display:flex;justify-content:flex-end;align-items:center;gap:20px}.filters{grid-area:f;display:flex;gap:8px;padding:10px 0;border-top:1px dashed var(--border-2);align-items:center}.brand{display:flex;align-items:center;gap:10px}.brand-mark{width:22px;height:22px;display:inline-grid;place-items:center;background:var(--ok);color:var(--bg);font-size:14px;border-radius:3px;box-shadow:0 0