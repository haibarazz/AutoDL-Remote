dashboard_js() {
  cat <<'EOF'
(function(){
  const pageKey = "autodl-dashboard:" + location.pathname;
  const stateSrc = window.__AUTODL_STATE_SRC__;
  const refreshSeconds = Number(window.__AUTODL_REFRESH_SECONDS__ || 0);
  let currentFilter = sessionStorage.getItem(pageKey + ":filter") || "all";
  function atBottom(el){ return el.scrollHeight - el.scrollTop - el.clientHeight < 24; }
  function captureTerms(){
    const terms = {};
    document.querySelectorAll(".term-body").forEach((el) => {
      const id = el.dataset.termId || "";
      terms[id] = { top: el.scrollTop, follow: atBottom(el) };
    });
    return terms;
  }
  function restoreTerms(prev){
    document.querySelectorAll(".term-body").forEach((el) => {
      const id = el.dataset.termId || "";
      const item = prev[id];
      if (!item || item.follow) el.scrollTop = el.scrollHeight;
      else el.scrollTop = item.top || 0;
      el.addEventListener("scroll", saveScroll, { passive: true });
    });
  }
  function saveScroll(){
    const next = { pageY: window.scrollY, terms: captureTerms() };
    sessionStorage.setItem(pageKey, JSON.stringify(next));
  }
  function setText(id, value){
    const el = document.getElementById(id);
    if (el) el.textContent = value == null ? "" : String(value);
  }
  function setHtml(id, value){
    const el = document.getElementById(id);
    if (el) el.innerHTML = value || "";
  }
  function applyFilter(filter){
    currentFilter = filter || "all";
    sessionStorage.setItem(pageKey + ":filter", currentFilter);
    document.querySelectorAll("[data-filter]").forEach((b) => b.classList.toggle("on", b.dataset.filter === currentFilter));
    document.querySelectorAll(".mc").forEach((card) => {
      card.hidden = currentFilter !== "all" && card.dataset.status !== currentFilter;
    });
  }
  function applyState(state){
    if (!state) return;
    const previousTerms = captureTerms();
    const previousY = window.scrollY;
    setText("brand-title", state.title);
    setText("brand-project", state.project);
    setText("clock-time", state.clock);
    setText("clock-date", state.generatedAt);
    setText("summary-online", `${state.onlineTotal}/${state.deviceTotal} 在线 · ${state.runTotal} RUNS`);
    setText("summary-counts", `${state.trainingTotal} training · ${state.idleTotal} idle · ${state.errorTotal} error · ${state.offlineTotal} offline`);
    setText("count-all", state.deviceTotal);
    setText("count-training", state.trainingTotal);
    setText("count-idle", state.idleTotal);
    setText("count-error", state.errorTotal);
    setText("count-offline", state.offlineTotal);
    setHtml("heatmap", state.heatCellsHtml);
    setHtml("device-grid", state.cardsHtml);
    setHtml("runs-root", state.runsHtml);
    setText("ticker-generated", `generated ${state.generatedAt}`);
    restoreTerms(previousTerms);
    applyFilter(currentFilter);
    window.scrollTo(0, previousY);
  }
  window.addEventListener("autodl-dashboard-state", (event) => applyState(event.detail));
  function loadState(){
    if (!stateSrc) return;
    const script = document.createElement("script");
    script.src = stateSrc + "?t=" + Date.now();
    script.async = true;
    script.onload = () => script.remove();
    script.onerror = () => script.remove();
    document.head.appendChild(script);
  }
  window.addEventListener("beforeunload", saveScroll);
  window.addEventListener("pagehide", saveScroll);
  document.querySelectorAll("[data-filter]").forEach((btn) => {
    btn.addEventListener("click", () => applyFilter(btn.dataset.filter));
  });
  applyState(window.__AUTODL_DASHBOARD_STATE__);
  const saved = JSON.parse(sessionStorage.getItem(pageKey) || "{}");
  if (typeof saved.pageY === "number") window.scrollTo(0, saved.pageY);
  if (refreshSeconds > 0) window.setInterval(loadState, refreshSeconds * 1000);
})();
EOF
}

render_dashboard_state() {
  local fleet="$1" state_path="$2" lines="$3" generated_at title output_dir tmp_state cards_tmp runs_tmp heat_tmp
  output_dir="$(dirname "$state_path")"
  mkdir -p "$output_dir"
  generated_at="$(date +%Y-%m-%dT%H:%M:%S%z)"
  if [ -n "$fleet" ]; then
    [ -d "$(fleet_dir "$fleet")" ] || die "Fleet not found: $fleet"
    title="Fleet $fleet"
  else
    title="Current Remote"
  fi

  DASHBOARD_DEVICE_TOTAL=0
  DASHBOARD_ONLINE_TOTAL=0
  DASHBOARD_TRAINING_TOTAL=0
  DASHBOARD_IDLE_TOTAL=0
  DASHBOARD_ERROR_TOTAL=0
  DASHBOARD_OFFLINE_TOTAL=0
  DASHBOARD_RUN_TOTAL=0
  DASHBOARD_HEAT_CELLS=""

  cards_tmp="$(mktemp "$output_dir/.dashboard-cards.XXXXXX")" || die "mktemp failed"
  runs_tmp="$(mktemp "$output_dir/.dashboard-runs.XXXXXX")" || { rm -f "$cards_tmp"; die "mktemp failed"; }
  heat_tmp="$(mktemp "$output_dir/.dashboard-heat.XXXXXX")" || { rm -f "$cards_tmp" "$runs_tmp"; die "mktemp failed"; }
  dashboard_device_cards "$fleet" "$lines" > "$cards_tmp"
  dashboard_run_tiles "$fleet" > "$runs_tmp"
  printf '%s' "$DASHBOARD_HEAT_CELLS" > "$heat_tmp"

  tmp_state="$(mktemp "$output_dir/.dashboard-state.XXXXXX")" || { rm -f "$cards_tmp" "$runs_tmp" "$heat_tmp"; die "mktemp failed"; }
  {
    printf '(function(){const d=(s)=>new TextDecoder().decode(Uint8Array.from(atob(s),c=>c.charCodeAt(0)));'
    printf 'const state={'
    printf 'generatedAt:%s,' "$(js_string "$generated_at")"
    printf 'clock:%s,' "$(js_string "$(date +%H:%M:%S)")"
    printf 'title:%s,' "$(js_string "$title")"
    printf 'project:%s,' "$(js_string "$PROJECT_ROOT")"
    printf 'deviceTotal:%s,onlineTotal:%s,trainingTotal:%s,idleTotal:%s,errorTotal:%s,offlineTotal:%s,runTotal:%s,' \
      "$DASHBOARD_DEVICE_TOTAL" "$DASHBOARD_ONLINE_TOTAL" "$DASHBOARD_TRAINING_TOTAL" "$DASHBOARD_IDLE_TOTAL" "$DASHBOARD_ERROR_TOTAL" "$DASHBOARD_OFFLINE_TOTAL" "$DASHBOARD_RUN_TOTAL"
    printf 'heatCellsHtml:d("%s"),' "$(base64_file_compact "$heat_tmp")"
    printf 'cardsHtml:d("%s"),' "$(base64_file_compact "$cards_tmp")"
    printf 'runsHtml:d("%s")' "$(base64_file_compact "$runs_tmp")"
    printf '};window.__AUTODL_DASHBOARD_STATE__=state;window.dispatchEvent(new CustomEvent("autodl-dashboard-state",{detail:state}));})();\n'
  } > "$tmp_state"
  mv "$tmp_state" "$state_path"
  rm -f "$cards_tmp" "$runs_tmp" "$heat_tmp"
}

render_dashboard() {
  local fleet="$1" output="$2" lines="$3" refresh_seconds="${4:-}" generated_at title output_dir tmp_output state_path state_src
  output_dir="$(dirname "$output")"
  mkdir -p "$output_dir"
  generated_at="$(date +%Y-%m-%dT%H:%M:%S%z)"
  if [ -n "$fleet" ]; then
    [ -d "$(fleet_dir "$fleet")" ] || die "Fleet not found: $fleet"
    title="Fleet $fleet"
  else
    title="Current Remote"
  fi
  state_path="$(dashboard_state_path "$output")"
  state_src="$(basename "$state_path")"
  render_dashboard_state "$fleet" "$state_path" "$lines"

  tmp_output="$(mktemp "$output_dir/.dashboard.XXXXXX")" || die "mktemp failed"
  {
    printf '<!doctype html><html lang="zh-CN"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>AutoDL Remote Dashboard</title><style>'
    dashboard_css
    printf '</style>'
    printf '</head><body><div class="app"><div class="scanlines"></div><div class="vignette"></div>'
    printf '<header class="topbar"><div class="topbar-l"><div class="brand"><span class="brand-mark">◇</span><span class="brand-name">AUTODL</span><span class="brand-sub">MONITOR</span><span class="brand-ver">v%s</span></div><div class="brand-tagline">— <span id="brand-title">%s</span> · <span id="brand-project">%s</span> —</div></div>' "$(html_escape "$PROGRAM_VERSION")" "$(html_escape "$title")" "$(html_escape "$PROJECT_ROOT")"
    printf '<div class="topbar-c"><div class="agg-block"><div class="agg-block-h"><span>TOTAL UTIL</span><span id="summary-online">loading</span></div><div id="heatmap" class="heatmap"></div><div id="summary-counts" class="agg-block-f">loading</div></div></div>'
    printf '<div class="topbar-r"><div class="clock"><div id="clock-time" class="clock-t">%s</div><div id="clock-date" class="clock-d">%s</div></div><div class="refresh"><span class="dim">REFRESH</span><div class="seg">' "$(date +%H:%M:%S)" "$(html_escape "$generated_at")"
    if [ -n "$refresh_seconds" ]; then
      printf '<button class="seg-btn on">%ss</button>' "$(html_escape "$refresh_seconds")"
    else
      printf '<button class="seg-btn on">manual</button>'
    fi
    printf '</div></div></div><div class="filters"><button class="flt on" data-filter="all"><span>全部</span><span id="count-all" class="flt-c">0</span></button><button class="flt" data-filter="training"><span>训练中</span><span id="count-training" class="flt-c">0</span></button><button class="flt" data-filter="idle"><span>空闲</span><span id="count-idle" class="flt-c">0</span></button><button class="flt" data-filter="error"><span>异常</span><span id="count-error" class="flt-c">0</span></button><button class="flt" data-filter="offline"><span>离线</span><span id="count-offline" class="flt-c">0</span></button></div></header>'
    printf '<main id="device-grid" class="grid"></main><div id="runs-root"></div>'
    printf '<div class="ticker"><span class="ticker-tag">EVT</span><div class="ticker-row"><span id="ticker-generated">generated %s</span><span>read-only dashboard</span><span>state updates without full page reload</span></div></div>' "$(html_escape "$generated_at")"
    printf '<script>window.__AUTODL_REFRESH_SECONDS__=%s;window.__AUTODL_STATE_SRC__=%s;</script>' "${refresh_seconds:-0}" "$(js_string "$state_src")"
    printf '<script src="%s"></script><script>' "$(html_escape "$state_src")"
    dashboard_js
    printf '</script></div></body></html>\n'
  } > "$tmp_output"
  mv "$tmp_output" "$output"
}

cmd_dashboard() {
  load_project
  local fleet="" output="" open_file=false watch_seconds="" lines=120 opened=false
  while [ $# -gt 0 ]; do
    case "$1" in
      --fleet) fleet="$2"; shift 2 ;;
      --output) output="$2"; shift 2 ;;
      --open) open_file=true; shift ;;
      --watch) watch_seconds="$2"; shift 2 ;;
      --lines) lines="$2"; shift 2 ;;
      *) die "unknown dashboard option: $1" ;;
    esac
  done
  case "$lines" in
    ""|*[!0-9]*) die "--lines must be a non-negative integer" ;;
  esac
  if [ -n "$watch_seconds" ]; then
    case "$watch_seconds" in
      ""|0|*[!0-9]*) die "--watch must be a positive integer number of seconds" ;;
    esac
  fi
  [ -z "$output" ] && output="$PROJECT_ROOT/$HISTORY_DIR/dashboard.html"
  if [ -n "$watch_seconds" ]; then
    render_dashboard "$fleet" "$output" "$lines" "$watch_seconds"
    info "Dashboard written: $output"
    if [ "$open_file" = "true" ] && [ "$opened" = "false" ]; then
      command -v open >/dev/null 2>&1 && open "$output" || info "open command not available."
      opened=true
    fi
    while :; do
      sleep "$watch_seconds"
      render_dashboard_state "$fleet" "$(dashboard_state_path "$output")" "$lines"
      info "Dashboard state updated: $(dashboard_state_path "$output")"
    done
  fi
  render_dashboard "$fleet" "$output" "$lines"
  info "Dashboard written: $output"
  if [ "$open_file" = "true" ]; then
    command -v open >/dev/null 2>&1 && open "$output" || info "open command not available."
  fi
}

cmd_shutdown() {
  load_project
  local wait_seconds=8 output rc
  while [ $# -gt 0 ]; do
    case "$1" in
      --wait) wait_seconds="$2"; shift 2 ;;
      *) die "unknown shutdown option: $1" ;;
    esac
  done

  info "Requesting remote shutdown for $ACCOUNT_TARGET:$ACCOUNT_PORT"
  output="$(ssh_capture "sync || true; if command -v shutdown >/dev/null 2>&1; then echo method=shutdown; nohup shutdown >/dev/null 2>&1 </dev/null & elif command -v poweroff >/dev/null 2>&1; then echo method=poweroff; nohup poweroff >/dev/null 2>&1 </dev/null & elif command -v halt >/dev/null 2>&1; then echo method=halt; nohup halt >/dev/null 2>&1 </dev/null & else echo method=missing; exit 127; fi" 2>&1)"
  rc=$?
  [ -n "$output" ] && printf '%s\n' "$output"

  if [ "$rc" -ne 0 ] && [ "$rc" -ne 255 ]; then
    info "shutdown_request=failed rc=$rc"
    return "$rc"
  fi
  if [ "$rc" -eq 255 ]; then
    info "shutdown_request=connection_closed rc=255"
  else
    info "shutdown_request=sent rc=$rc"
  fi

  sleep "$wait_seconds"
  if ssh_capture "true" >/dev/null 2>&1; then
    info "shutdown_status=still_reachable"
    info "Remote is still reachable; shutdown may not have taken effect."
    return 1
  fi
  info "shutdown_status=disconnected"
  info "SSH is disconnected; remote is likely shutting down or already powered off."
  write_history shutdown "wait=$wait_seconds rc=$rc"
}

cmd_model_dir() {
  load_project
  local create=false
  while [ $# -gt 0 ]; do
    case "$1" in
      --mkdir) create=true; shift ;;
      *) die "unknown model-dir option: $1" ;;
    esac
  done
  if [ "$create" = "true" ]; then
    ensure_remote_dir "$PROJECT_MODEL_DIR"
  fi
  info "$PROJECT_MODEL_DIR"
}

cmd_put_run() {
  local uploads=()
  while [ $# -gt 0 ]; do
    case "$1" in
      --) shift; break ;;
      *) uploads+=("$1"); shift ;;
    esac
  done
  [ "${#uploads[@]}" -gt 0 ] || die "put-run requires at least one local path before --"
  [ $# -gt 0 ] || die "put-run requires a command after --"
  local path
  for path in "${uploads[@]}"; do
    cmd_put "$path"
  done
  cmd_exec -- "$@"
}

cmd_shell() {
  load_project
  ssh_common_args
  run_transport ssh -t "${SSH_ARGS[@]}" "$ACCOUNT_TARGET" "cd $(shell_quote "$REMOTE_ROOT") && exec bash -l"
}

cmd_history() {
  load_project
  local lines=20 file
  while [ $# -gt 0 ]; do
    case "$1" in
      --lines) lines="$2"; shift 2 ;;
      *) die "unknown history option: $1" ;;
    esac
  done
  file="$PROJECT_ROOT/$HISTORY_DIR/history.jsonl"
  [ -f "$file" ] || { info "No history yet."; return 0; }
  tail -n "$lines" "$file"
}

main() {
  [ $# -gt 0 ] || { usage; exit 0; }
  local cmd="$1"
  shift
  case "$cmd" in
    -h|--help|help) usage ;;
    -V|--version|version) cmd_version ;;
    account) cmd_account "$@" ;;
    bind) cmd_bind "$@" ;;
    doctor) cmd_doctor "$@" ;;
    model-dir) cmd_model_dir "$@" ;;
    fleet) cmd_fleet "$@" ;;
    dashboard) cmd_dashboard "$@" ;;
    exec) cmd_exec "$@" ;;
    put-run) cmd_put_run "$@" ;;
    put|sync-up) cmd_put "$@" ;;
    get|sync-down) cmd_get "$@" ;;
    tree) cmd_tree "$@" ;;
    ls) cmd_ls "$@" ;;
    cat) cmd_cat "$@" ;;
    tail) cmd_tail "$@" ;;
    job) cmd_job "$@" ;;
    run) cmd_run "$@" ;;
    shutdown) cmd_shutdown "$@" ;;
    shell) cmd_shell "$@" ;;
    history) cmd_history "$@" ;;
    *) die "unknown command: $cmd" ;;
  esac
}

main "$@"
